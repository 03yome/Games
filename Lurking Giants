local Rayfield = loadstring(game:HttpGet("https://sirius.menu/rayfield"))()

local Window = Rayfield:CreateWindow({
    Name = "Lurking Giants",
    LoadingTitle = "by @romd3976",
    LoadingSubtitle = "Price Control",
    ConfigurationSaving = { Enabled = false }
})

local Tab = Window:CreateTab("Main", 4483362458)

_G.ESPEnabled = false
local activeESPs = {}

local ESP_COLOR = Color3.fromRGB(255, 0, 0)
local FILL_TRANSPARENCY = 0.5
local OUTLINE_TRANSPARENCY = 0

local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local monstersFolder = Workspace:WaitForChild("GameSettings")
                               :WaitForChild("FuncAssets")
                               :WaitForChild("ShopBackground")
                               :WaitForChild("Monsters")

local function createESP(model)
    if not _G.ESPEnabled then return end
    if model == LocalPlayer.Character or model.Name == LocalPlayer.Name or model:IsA("Player") then return end
    if activeESPs[model] then return end

    local highlight = Instance.new("Highlight")
    highlight.Name = "ESP_Highlight"
    highlight.FillColor = ESP_COLOR
    highlight.FillTransparency = FILL_TRANSPARENCY
    highlight.OutlineColor = ESP_COLOR
    highlight.OutlineTransparency = OUTLINE_TRANSPARENCY
    highlight.Adornee = model
    highlight.Parent = model

    activeESPs[model] = highlight
end

local function removeESP(model)
    if activeESPs[model] then
        activeESPs[model]:Destroy()
        activeESPs[model] = nil
    end
end

local function clearAllESP()
    for model, highlight in pairs(activeESPs) do
        if highlight then
            highlight:Destroy()
        end
    end
    activeESPs = {}
end

monstersFolder.ChildAdded:Connect(function(child)
    task.defer(function()
        if child:IsA("Model") and _G.ESPEnabled then
            createESP(child)
        end
    end)
end)

monstersFolder.ChildRemoved:Connect(function(child)
    if child:IsA("Model") then
        removeESP(child)
    end
end)

local Toggle = Tab:CreateToggle({
   Name = "Monster ESP",
   CurrentValue = false,
   Flag = "MonsterESP_Flag", 
   Callback = function(Value)
       _G.ESPEnabled = Value
       if _G.ESPEnabled then
           for _, child in ipairs(monstersFolder:GetChildren()) do
               if child:IsA("Model") then
                   createESP(child)
               end
           end
       else
           clearAllESP()
       end
   end,
})
