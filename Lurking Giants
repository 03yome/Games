})

local Tab = Window:CreateTab("Main", 4483362458)

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local MonstersFolder = workspace:WaitForChild("GameSettings", 5)
    and workspace.GameSettings:WaitForChild("FuncAssets", 5)
    and workspace.GameSettings.FuncAssets:WaitForChild("ShopBackground", 5)
    and workspace.GameSettings.FuncAssets.ShopBackground:WaitForChild("Monsters", 5)

local ESP_Cache = {}
local ESP_Enabled = false

local function CreateESP(model)
    if ESP_Cache[model] then return end
    
    local box = Drawing.new("Square")
    box.Color = Color3.fromRGB(255, 0, 0)
    box.Thickness = 1.5
    box.Filled = false
    box.Visible = false

    ESP_Cache[model] = {Box = box}
end

local function RemoveESP(model)
    if ESP_Cache[model] then
        ESP_Cache[model].Box:Remove()
        ESP_Cache[model] = nil
    end
end

local UpdateConnection
UpdateConnection = RunService.RenderStepped:Connect(function()
    if not ESP_Enabled or not MonstersFolder then
        for _, esp in pairs(ESP_Cache) do
            esp.Box.Visible = false
        end
        return
    end

    for _, monster in ipairs(MonstersFolder:GetChildren()) do
        if monster:IsA("Model") and monster.Name ~= LocalPlayer.Name then
            local primaryPart = monster.PrimaryPart or monster:FindFirstChildWhichIsA("BasePart")
            
            if primaryPart then
                local vector, onScreen = Camera:WorldToViewportPoint(primaryPart.Position)
                
                if onScreen then
                    if not ESP_Cache[monster] then
                        CreateESP(monster)
                    end
                    
                    local esp = ESP_Cache[monster]
                    local sizeX = 1000 / vector.Z
                    local sizeY = 1500 / vector.Z
                    
                    esp.Box.Size = Vector2.new(sizeX, sizeY)
                    esp.Box.Position = Vector2.new(vector.X - sizeX / 2, vector.Y - sizeY / 2)
                    esp.Box.Visible = true
                else
                    if ESP_Cache[monster] then
                        ESP_Cache[monster].Box.Visible = false
                    end
                end
            end
        end
    end

    for model, _ in pairs(ESP_Cache) do
        if not model or not model:IsDescendantOf(MonstersFolder) then
            RemoveESP(model)
        end
    end
end)

local Toggle = Tab:CreateToggle({
   Name = "Monsters ESP",
   CurrentValue = false,
   Flag = "MonsterESP_Flag",
   Callback = function(Value)
       ESP_Enabled = Value
       if not Value then
           for model, _ in pairs(ESP_Cache) do
               RemoveESP(model)
           end
       end
   end,
})

