MinBtn.Position = UDim2.new(1, -30, 0, 0)
MinBtn.Text = "-"
MinBtn.BackgroundColor3 = Color3.fromRGB(40,40,40)
MinBtn.TextColor3 = Color3.new(1,1,1)

--// SCROLL GET TOOL
local Scroll = Instance.new("ScrollingFrame", Main)
Scroll.Size = UDim2.new(1, 0, 1, -30)
Scroll.Position = UDim2.new(0, 0, 0, 30)
Scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
Scroll.ScrollBarThickness = 6
Scroll.BackgroundTransparency = 1

local Layout = Instance.new("UIListLayout", Scroll)

--// GIVE TOOL
local function giveTool(tool)
    local char = player.Character or player.CharacterAdded:Wait()
    local humanoid = char:WaitForChild("Humanoid")

    local clone = tool:Clone()
    clone.Parent = backpack

    task.wait(0.15)

    pcall(function()
        humanoid:EquipTool(clone)
    end)

    if clone:FindFirstChild("Handle") then
        pcall(function()
            clone:Activate()
        end)
    end
end

--// CREATE BUTTON TOOL
for _, tool in pairs(tools) do
    local Btn = Instance.new("TextButton", Scroll)
    Btn.Size = UDim2.new(1, -10, 0, 35)
    Btn.Text = tool.Name
    Btn.BackgroundColor3 = Color3.fromRGB(35,35,35)
    Btn.TextColor3 = Color3.new(1,1,1)

    Btn.MouseButton1Click:Connect(function()
        giveTool(tool)
    end)
end

task.wait()
Scroll.CanvasSize = UDim2.new(0, 0, 0, Layout.AbsoluteContentSize.Y)

--// DELETE GUI
local DelFrame = Instance.new("Frame", Main)
DelFrame.Size = UDim2.new(0, 260, 0, 250)
DelFrame.Position = UDim2.new(0, 270, 0, 0)
DelFrame.BackgroundColor3 = Color3.fromRGB(25,25,25)
DelFrame.Active = true
DelFrame.Draggable = true

local DelTitle = Instance.new("TextLabel", DelFrame)
DelTitle.Size = UDim2.new(1, 0, 0, 30)
