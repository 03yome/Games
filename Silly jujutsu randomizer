local DelScroll = Instance.new("ScrollingFrame", DelFrame)
DelScroll.Size = UDim2.new(1, 0, 1, -30)
DelScroll.Position = UDim2.new(0, 0, 0, 30)
DelScroll.ScrollBarThickness = 6
DelScroll.BackgroundTransparency = 1

local DelLayout = Instance.new("UIListLayout", DelScroll)

--// TOOL NAME SYSTEM (KHÔNG BUG)
local function getAllToolNames()
    local names = {}
    local added = {}

    backpack = player:WaitForChild("Backpack")

    for _, v in pairs(backpack:GetChildren()) do
        if v:IsA("Tool") and not added[v.Name] then
            added[v.Name] = true
            table.insert(names, v.Name)
        end
    end

    local char = player.Character
    if char then
        for _, v in pairs(char:GetChildren()) do
            if v:IsA("Tool") and not added[v.Name] then
                added[v.Name] = true
                table.insert(names, v.Name)
            end
        end
    end

    return names
end

local function findTool(name)
    backpack = player:WaitForChild("Backpack")

    for _, v in pairs(backpack:GetChildren()) do
        if v:IsA("Tool") and v.Name == name then
            return v
        end
    end

    local char = player.Character
    if char then
        for _, v in pairs(char:GetChildren()) do
            if v:IsA("Tool") and v.Name == name then
                return v
            end
        end
    end
end

--// REFRESH DELETE GUI (FINAL FIX)
local function refreshDeleteGUI()
    for _, v in pairs(DelScroll:GetChildren()) do
        if v:IsA("TextButton") then
            v:Destroy()
        end
    end

    local names = getAllToolNames()

    for _, name in pairs(names) do
        local Btn = Instance.new("TextButton")
        Btn.Size = UDim2.new(1, -10, 0, 30)
        Btn.Text = "Xóa: "..name
        Btn.BackgroundColor3 = Color3.fromRGB(80,30,30)
        Btn.TextColor3 = Color3.new(1,1,1)
        Btn.Parent = DelScroll

        Btn.MouseButton1Click:Connect(function()
            local tool = findTool(name)
            if tool then
                tool:Destroy()
            end
            refreshDeleteGUI()
        end)
    end

    task.wait()
    DelScroll.CanvasSize = UDim2.new(0, 0, 0, DelLayout.AbsoluteContentSize.Y)
end

--// LOOP CHỐNG DIE (NHẸ)
task.spawn(function()
    while true do
        task.wait(0.5)
        pcall(refreshDeleteGUI)
    end
end)

refreshDeleteGUI()

