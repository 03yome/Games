-- Hàm hiển thị và cập nhật danh sách
local function showInventory()
    if scrollingFrame.Visible then
        scrollingFrame.Visible = false
        searchBox.Visible = false
    else
        local player = game.Players.LocalPlayer
        local backpack = player:WaitForChild("Backpack")
        local character = player.Character or player.CharacterAdded:Wait()
        local humanoid = character:WaitForChild("Humanoid")

        -- Xóa danh sách cũ trước khi tải danh sách mới
        for _, child in pairs(scrollingFrame:GetChildren()) do
            if child:IsA("TextButton") then
                child:Destroy()
            end
        end

        local yPosition = 10
        -- Quét qua tất cả các Tool trong Backpack
        for _, item in pairs(backpack:GetChildren()) do
            if item:IsA("Tool") then
                -- Tạo Nút bấm thay vì TextLabel thông thường
                local itemButton = Instance.new("TextButton")
                itemButton.Parent = scrollingFrame
                itemButton.Size = UDim2.new(0, 560, 0, 40) 
                itemButton.Position = UDim2.new(0, 10, 0, yPosition)
                itemButton.Text = item.Name
                itemButton.TextSize = 18
                itemButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
                itemButton.TextColor3 = Color3.fromRGB(255, 255, 255)
                itemButton.Name = item.Name
                
                -- Hiệu ứng bo góc nhẹ cho nút bấm
                local uiCorner = Instance.new("UICorner")
                uiCorner.CornerRadius = UDim.new(0, 6)
                uiCorner.Parent = itemButton

                -- Sự kiện khi bấm vào vật phẩm -> Trang bị lên tay
                itemButton.MouseButton1Click:Connect(function()
                    if item and item.Parent == backpack then
                        humanoid:EquipTool(item) 
                    end
                end)

                yPosition = yPosition + 45
            end
        end

        -- Cập nhật lại thanh cuộn dựa trên số lượng item thực tế
        scrollingFrame.CanvasSize = UDim2.new(0, 0, 0, yPosition)

        scrollingFrame.Visible = true
        searchBox.Visible = true
    end
end

-- Bộ lọc tìm kiếm
searchBox.Changed:Connect(function(property)
    if property == "Text" then
        local searchText = searchBox.Text:lower()

        for _, itemButton in pairs(scrollingFrame:GetChildren()) do
            if itemButton:IsA("TextButton") then
                if searchText == "" or itemButton.Name:lower():find(searchText) then
                    itemButton.Visible = true
                else
                    itemButton.Visible = false
                end
            end
        end
    end
end)

Button.MouseButton1Click:Connect(showInventory)
