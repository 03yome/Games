-- Hàm dịch chuyển an toàn
local function teleport(cframe)
    local character = LocalPlayer.Character
    if character and character:FindFirstChild("HumanoidRootPart") then
        character.HumanoidRootPart.CFrame = cframe
    end
end

-- Xử lý Logic Nút 1: Tìm Center và dịch chuyển
BtnCenter.MouseButton1Click:Connect(function()
    local map = workspace:FindFirstChild("Map")
    if not map then
        print("Không tìm thấy thư mục 'Map' trong Workspace!")
        return
    end

    -- Tìm tất cả các object tên là "Center" nằm trong Map
    local centers = {}
    for _, child in ipairs(map:GetChildren()) do
        if child.Name == "Center" then
            table.insert(centers, child)
        end
    end

    -- Kiểm tra nếu không tìm thấy Center nào
    if #centers == 0 then
        print("Không thấy center nào")
        return
    end

    -- Chọn Center để dịch chuyển
    local targetCenter
    if #centers == 1 then
        targetCenter = centers[1]
        print("Tìm thấy 1 Center duy nhất. Đang dịch chuyển...")
    else
        -- Nếu có nhiều Center, lấy ngẫu nhiên 1 cái
        local randomIndex = math.random(1, #centers)
        targetCenter = centers[randomIndex]
        print("Tìm thấy " .. #centers .. " Centers. Đang dịch chuyển đến Center ngẫu nhiên số: " .. randomIndex)
    end

    -- Dịch chuyển đến vị trí của Center (Nếu là BasePart hoặc Model đều lấy được CFrame)
    if targetCenter:IsA("BasePart") then
        teleport(targetCenter.CFrame)
    elseif targetCenter:IsA("Model") then
        local primaryPart = targetCenter.PrimaryPart or targetCenter:FindFirstChildWhichIsA("BasePart")
        if primaryPart then
            teleport(primaryPart.CFrame)
        else
            teleport(targetCenter:GetPivot())
        end
    end
end)

