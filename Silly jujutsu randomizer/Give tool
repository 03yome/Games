local function AddScriptButton(buttonName, buttonColor, customFunction)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -5, 0, 35)
    btn.BackgroundColor3 = buttonColor
    btn.Text = buttonName
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 14
    btn.Parent = scrollFrame1

    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 5)
    btnCorner.Parent = btn

    local canClick = true
    btn.MouseButton1Click:Connect(function()
        if not canClick then return end
        canClick = false
        local oldColor = btn.BackgroundColor3
        btn.BackgroundColor3 = Color3.fromRGB(oldColor.R * 100, oldColor.G * 100, oldColor.B * 100)
        task.spawn(customFunction) 
        task.wait(0.3)
        btn.BackgroundColor3 = oldColor
        canClick = true
    end)
end

