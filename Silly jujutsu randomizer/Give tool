-- BỘ LẮNG NGHE ĐỒNG BỘ
local function SetupListeners()
    local bk = player:WaitForChild("Backpack", 5)
    if bk then bk.ChildAdded:Connect(UpdateBackpackUI) bk.ChildRemoved:Connect(UpdateBackpackUI) end
    if player.Character then player.Character.ChildAdded:Connect(UpdateBackpackUI) player.Character.ChildRemoved:Connect(UpdateBackpackUI) end
    UpdateBackpackUI()
end
player.CharacterAdded:Connect(function(char) task.wait(0.5) SetupListeners() end)

