local cachedSourceTools = {}

local function updateScrollCanvas(scrollFrame, layout)
    scrollFrame.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 10)
end

local function SAFELY_DESTROY_TOOL(toolInstance)
    local character = player.Character
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    
    if toolInstance.Parent == character and humanoid then
        humanoid:UnequipTools()
        task.wait(0.1)
    end
    
    toolInstance.Name = "DELETED_TOOL" 
    toolInstance.Parent = nil
    task.wait(0.05)
    toolInstance:Destroy()
end

local function GIVE_TOOL_SAFE(originalTool)
    local backpack = player:FindFirstChildOfClass("Backpack")
    if not backpack then return false end
    
    local toolName = originalTool.Name
    local alreadyHas = backpack:FindFirstChild(toolName) or (player.Character and player.Character:FindFirstChild(toolName))
    
    if not alreadyHas then
        local clone = originalTool:Clone()
        clone.Parent = backpack
        
        task.spawn(function()
            local char = player.Character
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            if hum then
                hum:EquipTool(clone)
                task.wait(0.05)
                hum:UnequipTools()
            end
        end)
        return true
    end
    return false
end

-- TỰ ĐỘNG QUÉT TOÀN BỘ GAME ĐỂ TÌM TOOL (KHÔNG PHỤ THUỘC TÊN THƯ MỤC CŨ)
local function AutoScanGameTools()
    for _, child in ipairs(leftScroll:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end
    cachedSourceTools = {}
    
    -- Dùng GetDescendants() để lục tung toàn bộ thư mục con trong ReplicatedStorage
    local allItems = ReplicatedStorage:GetDescendants()
    local foundCount = 0

    for _, item in ipairs(allItems) do
        if item:IsA("Tool") then
            local lowerName = string.lower(item.Name)
            -- Tránh lấy trùng các tool có tên giống nhau ở nhiều chỗ
            if not cachedSourceTools[lowerName] then
                cachedSourceTools[lowerName] = item
                foundCount = foundCount + 1
            end
        end
    end

    -- Đưa danh sách đã quét được lên UI
    for _, originalTool in pairs(cachedSourceTools) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -10, 0, 30)
        btn.BackgroundColor3 = Color3.fromRGB(45, 55, 45)
        btn.Text = "  + " .. originalTool.Name
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.TextXAlignment = Enum.TextXAlignment.Left
        btn.Parent = leftScroll

        btn.MouseButton1Click:Connect(function()
            if GIVE_TOOL_SAFE(originalTool) then
                statusLabel.Text = "Hệ thống: Đã lấy thành công " .. originalTool.Name
                statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
            else
                statusLabel.Text = "Hệ thống: Bạn đã có vũ khí này rồi!"
                statusLabel.TextColor3 = Color3.fromRGB(255, 150, 0)
            end
        end)
    end
    
    updateScrollCanvas(leftScroll, leftLayout)
    statusLabel.Text = "Hệ thống: Đã quét thấy tổng cộng " .. foundCount .. " Tools trong game!"
    statusLabel.TextColor3 = Color3.fromRGB(100, 255, 255)
end

-- ĐỒNG BỘ TÚI ĐỒ (BÊN PHẢI)
local function UpdateBackpackUI()
    for _, child in ipairs(rightScroll:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end
    local backpack = player:FindFirstChildOfClass("Backpack")
    local character = player.Character
    local listTools = {}

    if backpack then for _, item in ipairs(backpack:GetChildren()) do if item:IsA("Tool") then table.insert(listTools, {instance = item, loc = "Túi"}) end end end
    if character then for _, item in ipairs(character:GetChildren()) do if item:IsA("Tool") then table.insert(listTools, {instance = item, loc = "Tay"}) end end end

    for _, toolData in ipairs(listTools) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -10, 0, 30)
        btn.BackgroundColor3 = toolData.loc == "Tay" and Color3.fromRGB(90, 50, 30) or Color3.fromRGB(70, 40, 40)
        btn.Text = "  ❌ [" .. toolData.loc .. "] " .. toolData.instance.Name
        btn.TextColor3 = Color3.fromRGB(255, 200, 200)
        btn.TextXAlignment = Enum.TextXAlignment.Left
        btn.Parent = rightScroll

        btn.MouseButton1Click:Connect(function()
            statusLabel.Text = "Hệ thống: Đang giải phóng bộ nhớ & xóa " .. toolData.instance.Name
            statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
            SAFELY_DESTROY_TOOL(toolData.instance)
        end)
    end
    updateScrollCanvas(rightScroll, rightLayout)
end

-- SỰ KIỆN COMBO TOOL
comboButton.MouseButton1Click:Connect(function()
    local text = comboTextBox.Text
    if text == "" then return end
    local count = 0
    for part in string.gmatch(text, "[^,]+") do
        local name = string.match(part, "^%s*(.-)%s*$")
        local target = cachedSourceTools[string.lower(name)]
        if target and GIVE_TOOL_SAFE(target) then count = count + 1 end
    end
    statusLabel.Text = "Hệ thống: Đã nạp thành công combo (" .. count .. " món mới)!"
    statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
end)

