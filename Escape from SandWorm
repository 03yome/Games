local Workspace = game:GetService("Workspace")

local targetWorms = {
    ["SandWorm"] = true,
    ["HookWorm"] = true,
    ["Gravemaw"] = true
}

local function applyESP(worm)
    if worm and worm:IsA("Model") and not worm:FindFirstChild("Worm_ESP") then
        local highlight = Instance.new("Highlight")
        highlight.Name = "Worm_ESP"
        highlight.FillColor = Color3.fromRGB(255, 50, 50)
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        highlight.FillTransparency = 0.5
        highlight.OutlineTransparency = 0
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        highlight.Adornee = worm
        highlight.Parent = worm
    end
end

local function removeESP(worm)
    if worm and worm:FindFirstChild("Worm_ESP") then
        worm.Worm_ESP:Destroy()
    end
end

local wormAddedConnection = nil

local Toggle = MainTab:Toggle({
