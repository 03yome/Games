local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local connections = {}

local function applyESP(player)
    if player == LocalPlayer then return end

    local function highlightCharacter(character)
        if not character then return end
        
        -- Kiểm tra nếu chưa có Highlight thì mới tạo
        if not character:FindFirstChild("Player_ESP") then
            local highlight = Instance.new("Highlight")
            highlight.Name = "Player_ESP"
            highlight.FillColor = Color3.fromRGB(0, 255, 0) -- Màu xanh lá
            highlight.OutlineColor = Color3.fromRGB(255, 255, 255) -- Viền trắng
            highlight.FillTransparency = 0.5
            highlight.OutlineTransparency = 0
            highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            highlight.Adornee = character
            highlight.Parent = character
        end
    end

    if player.Character then
        highlightCharacter(player.Character)
    end

    connections[player] = player.CharacterAdded:Connect(function(character)
        task.wait(0.1)
        highlightCharacter(character)
    end)
end

local function removeESP(player)
    if player.Character and player.Character:FindFirstChild("Player_ESP") then
        player.Character.Player_ESP:Destroy()
    end
    
    if connections[player] then
        connections[player]:Disconnect()
        connections[player] = nil
    end
end

local playerAddedConnection = nil
local playerRemovingConnection = nil

local Toggle = MainTab:Toggle({
    Title = "Esp players",
    Value = false,
    Callback = function(state) 
        if state then
            for _, player in ipairs(Players:GetPlayers()) do
                applyESP(player)
            end

            playerAddedConnection = Players.PlayerAdded:Connect(function(player)
                applyESP(player)
            end)

            playerRemovingConnection = Players.PlayerRemoving:Connect(function(player)
                removeESP(player)
            end)
        else
            if playerAddedConnection then
                playerAddedConnection:Disconnect()
                playerAddedConnection = nil
            end
            if playerRemovingConnection then
                playerRemovingConnection:Disconnect()
                playerRemovingConnection = nil
            end

            for _, player in ipairs(Players:GetPlayers()) do
                removeESP(player)
            end
        end
    end
})

local Workspace = game:GetService("Workspace")

local Toggle = MainTab:Toggle({
    Title = "create part",
    Value = false,
    Callback = function(state) 
        if state then
            local folder = Workspace:FindFirstChild("AntiDetectParts")
            if not folder then
                folder = Instance.new("Folder")
                folder.Name = "AntiDetectParts"
                folder.Parent = Workspace
            end

            local detectionFolder = Workspace:FindFirstChild("DesertTown") 
                and Workspace.DesertTown:FindFirstChild("SpecialParts")
                and Workspace.DesertTown.SpecialParts:FindFirstChild("Detectionparts")

            if detectionFolder then
                local count = 0
                for _, part in ipairs(detectionFolder:GetChildren()) do
                    if part:IsA("BasePart") and part.Name:find("DetectionPart") then
                        local newPart = Instance.new("Part")
                        newPart.Name = part.Name .. "_Copied"
                        newPart.Size = part.Size
                        
                        newPart.CFrame = part.CFrame * CFrame.new(0, 0.5, 0)
                        
                        newPart.Transparency = 0.25
                        newPart.Anchored = true
                        newPart.CanCollide = true
                        newPart.Material = Enum.Material.SmoothPlastic
                        newPart.Color = Color3.fromRGB(0, 255, 255)
                        
                        newPart.Parent = folder
                        count = count + 1
                    end
                end
                print("[AntiDetect] Đã tạo thành công " .. tostring(count) .. " parts từ Detectionparts!")
            else
                warn("[AntiDetect] Không tìm thấy Workspace.DesertTown.SpecialParts.Detectionparts!")
            end
        else
            local folder = Workspace:FindFirstChild("AntiDetectParts")
            if folder then
                folder:Destroy()
                print("[AntiDetect] Đã xóa thư mục AntiDetectParts!")
            end
        end
    end
})

