-- Cấu hình vật phẩm mua
local pickaxes = {"Ruby Pickaxe"}
local autoBuyEnabled = false

-- Vòng lặp mua tự động (Sử dụng task.spawn để không làm đơ game)
local function startAutoBuy()
    task.spawn(function()
        while autoBuyEnabled do
            for _, pickaxeName in ipairs(pickaxes) do
                if not autoBuyEnabled then break end
                
                local args = {
                    [1] = {["Type"] = "Post"},
                    [2] = "BUY_PICKAXESHOP",
                    [3] = pickaxeName
                }
                
                networkEvent:FireServer(unpack(args))
                statusLabel.Text = "🛒 Buying: " .. pickaxeName
                task.wait(0.05) -- Tốc độ mua cực nhanh
            end
            
            if autoBuyEnabled then
                statusLabel.Text = "🔁 Restarting loop..."
                task.wait(2)
            end
        end
    end)
end

-- Xử lý bấm nút duy nhất (Bật -> Tắt -> Bật)
toggleButton.MouseButton1Click:Connect(function()
    autoBuyEnabled = not autoBuyEnabled
    
    if autoBuyEnabled then
        -- Chuyển trạng thái sang ON
        toggleButton.Text = "▶️ RUNNING"
        toggleButton.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        startAutoBuy()
    else
        -- Chuyển trạng thái sang OFF
        toggleButton.Text = "⏹️ STOPPED"
        toggleButton.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
        statusLabel.Text = "Waiting..."
    end
end)

closeButton.MouseButton1Click:Connect(function()
    autoBuyEnabled = false
    screenGui:Destroy()
end)

-- HỆ THỐNG KÉO THẢ (Hỗ trợ tốt cho cả PC và Mobile)
local dragging, dragInput, dragStart, startPos

title.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = frame.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

title.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
