-- Hàm xử lý chạm vật lý gõ thẳng vào Class hệ thống
local function fireTouch(part)
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    -- Kích hoạt lệnh chạm (0 = Chạm vào, 1 = Thả ra)
    firetouchinterest(hrp, part, 0)
    task.wait()
    firetouchinterest(hrp, part, 1)
end

-- Hàm tìm kiếm đường dẫn an toàn từng bước (Sửa lỗi logic của ChatGPT)
local function getEnterPart()
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return nil end
    
    local plot = plots:FindFirstChild("x5_oz6")
    if not plot then return nil end
    
    local interact = plot:FindFirstChild("Interact")
    if not interact then return nil end
    
    return interact:FindFirstChild("Enter")
end

-- Sự kiện Click nút bấm từ tay bạn
button.MouseButton1Click:Connect(function()
    local enter = getEnterPart()

    if enter and enter:IsA("BasePart") then
        -- Tạo hiệu ứng đổi màu nhẹ để biết nút có phản hồi
        button.BackgroundColor3 = Color3.fromRGB(0, 200, 255)
        
        fireTouch(enter)
        
        task.wait(0.1)
        button.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
    else
        warn("Không tìm thấy đường dẫn đên khối Enter!")
    end
end)

