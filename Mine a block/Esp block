local CoreGui = game:GetService("CoreGui")
local blocksFolder = workspace:WaitForChild("Mid"):WaitForChild("Blocks")

-- Định nghĩa các màu sắc quặng theo hệ thống của bạn
local COLOR_BASE = Color3.fromRGB(110, 110, 110)      -- Đá nền xám (Điều kiện bắt buộc)
local COLOR_DIAMOND = Color3.fromRGB(149, 227, 255)   -- Kim Cương (Quặng đính đá)
local COLOR_EMERALD = Color3.fromRGB(102, 204, 102)   -- Ngọc Lục Bảo (Quặng đính đá)
local COLOR_LIGHTNING = Color3.fromRGB(248, 248, 248) -- Lightning (Cần check nền xám)

local COLOR_SAPPHIRE = Color3.fromRGB(61, 67, 144)    -- Sapphire (Không cần nền xám)
local COLOR_GOLD = Color3.fromRGB(185, 159, 57)       -- Gold Block (Không cần nền xám)
local COLOR_LUCKY = Color3.fromRGB(255, 192, 44)      -- Lucky Block (Không cần nền xám)
local COLOR_DIAMOND_BLOCK = Color3.fromRGB(111, 205, 255) -- Kim Cương Block (Không cần nền xám - Cần chữ M)
local COLOR_EMERALD_BLOCK = Color3.fromRGB(103, 193, 103) -- Ngọc Lục Bảo Block (Không cần nền xám - Cần chữ M)

-- Quản lý các khung ESP trong CoreGui
local ESPContainer = CoreGui:FindFirstChild("BlockESPContainer") or Instance.new("Folder")
if not ESPContainer.Parent then
	ESPContainer.Name = "BlockESPContainer"
	ESPContainer.Parent = CoreGui
end

-- Hàm xóa sạch dữ liệu ESP cũ
local function clearOldESP()
	ESPContainer:ClearAllChildren()
end

-- Hàm so sánh màu sắc chính xác
local function isColorMatch(c1, c2)
	return math.abs(c1.R - c2.R) < 0.005 
	   and math.abs(c1.G - c2.G) < 0.005 
	   and math.abs(c1.B - c2.B) < 0.005
end

-- Hàm tạo nhãn chữ "M" xuyên tường cho các khối Block Nguyên Chất
local function createTextLabelM(target, espColor)
	local billboard = Instance.new("BillboardGui")
	billboard.Name = "LabelM"
	billboard.Adornee = target
	billboard.Size = UDim2.new(0, 50, 0, 50)
	billboard.AlwaysOnTop = true -- Giúp chữ nhìn xuyên qua mọi lớp đá đất
	
	local textLabel = Instance.new("TextLabel")
	textLabel.Size = UDim2.new(1, 0, 1, 0)
	textLabel.BackgroundTransparency = 1
	textLabel.Text = "M"
	textLabel.Font = Enum.Font.GothamBold
	textLabel.TextSize = 24
	textLabel.TextColor3 = espColor
	textLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0) -- Viền chữ màu đen cho dễ nhìn
	textLabel.TextStrokeTransparency = 0
	textLabel.Parent = billboard
	
	billboard.Parent = target
end

-- Hàm kiểm tra cấu trúc Model và trả về màu Highlight tương ứng kèm tag nhận diện loại block
local function validateAndGetOreColor(model)
	local hasBaseGrey = false
	local hasDiamond = false
	local hasEmerald = false
	local hasLightning = false
	
	local hasSapphire = false
	local hasGold = false
	local hasLucky = false
	local hasDiamondBlock = false
	local hasEmeraldBlock = false

	for _, child in ipairs(model:GetDescendants()) do
		if child:IsA("BasePart") then
			local c = child.Color
			if isColorMatch(c, COLOR_BASE) then
				hasBaseGrey = true
			elseif isColorMatch(c, COLOR_DIAMOND) then
				hasDiamond = true
			elseif isColorMatch(c, COLOR_EMERALD) then
				hasEmerald = true
			elseif isColorMatch(c, COLOR_LIGHTNING) then
				hasLightning = true
			elseif isColorMatch(c, COLOR_SAPPHIRE) then
				hasSapphire = true
			elseif isColorMatch(c, COLOR_GOLD) then
				hasGold = true
			elseif isColorMatch(c, COLOR_LUCKY) then
				hasLucky = true
			elseif isColorMatch(c, COLOR_DIAMOND_BLOCK) then
				hasDiamondBlock = true
			elseif isColorMatch(c, COLOR_EMERALD_BLOCK) then
				hasEmeraldBlock = true
			end
		end
	end

	-- Trả về: Màu sắc, và biến Boolean xác định xem có phải là "Block nguyên chất" cần chữ M không
	if hasSapphire then
		return COLOR_SAPPHIRE, false
	elseif hasGold then
		return COLOR_GOLD, false
	elseif hasLucky then
		return COLOR_LUCKY, false
	elseif hasDiamondBlock then
		return COLOR_DIAMOND_BLOCK, true -- Cần chữ M
	elseif hasEmeraldBlock then
		return COLOR_EMERALD_BLOCK, true -- Cần chữ M
	end

	if hasBaseGrey then
		if hasDiamond then
			return COLOR_DIAMOND, false
		elseif hasEmerald then
			return COLOR_EMERALD, false
		elseif hasLightning then
			return COLOR_LIGHTNING, false
		end
	end
	
	return nil, false
end

-- Hàm tạo hiệu ứng phát sáng Highlight xuyên tường cho Model
local function applyESP(model, espColor, needTextM)
	if ESPContainer:FindFirstChild(model.Name .. "_ESP") then return end

	local highlight = Instance.new("Highlight")
	highlight.Name = model.Name .. "_ESP"
	highlight.Adornee = model
	
	highlight.FillColor = espColor
	highlight.FillTransparency = 0.4 
	highlight.OutlineColor = Color3.fromRGB(255, 255, 255) 
	highlight.OutlineTransparency = 0
	highlight.Parent = ESPContainer
	
	-- Nếu thuộc nhóm Kim Cương Block hoặc Ngọc Lục Bảo Block, tạo thêm chữ M lơ lửng
	if needTextM then
		-- Tìm một BasePart bất kỳ trong Model để gắn chữ lên tâm của nó
		local mainPart = model:IsA("BasePart") and model or model:FindFirstChildWhichIsA("BasePart")
		if mainPart then
			-- Xóa chữ M cũ phòng hờ trùng lặp
			if mainPart:FindFirstChild("LabelM") then mainPart.LabelM:Destroy() end
			createTextLabelM(mainPart, espColor)
		end
	end
end

-- Hàm xử lý quét khối block
local function processBlock(item)
	if item:IsA("Model") then
		local matchedColor, needTextM = validateAndGetOreColor(item)
		if matchedColor then
			applyESP(item, matchedColor, needTextM)
		end
	elseif item:IsA("BasePart") then
		local c = item.Color
		if isColorMatch(c, COLOR_SAPPHIRE) then
			applyESP(item, COLOR_SAPPHIRE, false)
		elseif isColorMatch(c, COLOR_GOLD) then
			applyESP(item, COLOR_GOLD, false)
		elseif isColorMatch(c, COLOR_LUCKY) then
			applyESP(item, COLOR_LUCKY, false)
		elseif isColorMatch(c, COLOR_DIAMOND_BLOCK) then
			applyESP(item, COLOR_DIAMOND_BLOCK, true) -- Cần chữ M
		elseif isColorMatch(c, COLOR_EMERALD_BLOCK) then
			applyESP(item, COLOR_EMERALD_BLOCK, true) -- Cần chữ M
		end
	end
end

-- Hàm làm mới toàn bộ danh sách ESP trên map
local function updateBlockESP()
	clearOldESP()
	for _, item in ipairs(blocksFolder:GetChildren()) do
		processBlock(item)
	end
end

-- Kích hoạt hệ thống quét lần đầu
updateBlockESP()

-- Tự động quét khi game sinh thêm block mới
blocksFolder.ChildAdded:Connect(function(child)
	task.wait(0.1)
	if child and child.Parent then
		processBlock(child)
	end
end)

-- Tự động xóa chi tiết ESP đi ngay khi khối quặng đó bị đào vỡ
blocksFolder.ChildRemoved:Connect(function(child)
	local associatedESP = ESPContainer:FindFirstChild(child.Name .. "_ESP")
	if associatedESP then
		associatedESP:Destroy()
	end
end)

print("=== ESP CẬP NHẬT: ĐÃ THÊM CHỮ M CHO KIM CƯƠNG & NGỌC LỤC BẢO BLOCK ===")
