        -- Fire the Remote
        game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("ZombieRelated"):WaitForChild("AcidSpit"):FireServer(unpack(args))

        task.wait(0)  -- Adjust this value to make the shots faster (lower value = faster)
