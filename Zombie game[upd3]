local function updateScriptPosition()
    local player = game.Players.LocalPlayer
    local character = player.Character or player.CharacterAdded:Wait()  -- Wait for character to load
    local humanoidRootPart = character:WaitForChild("HumanoidRootPart")  -- Wait for HumanoidRootPart to load

    for i = 1, numShots do
        if not enabled then
            break  -- Exit the loop if the script is disabled
        end
        
        -- Randomly generate x, y, z offset within a range
        local randomOffset = Vector3.new(
            math.random(-radius, radius),  -- Random x within range
            math.random(-radius, radius),  -- Random y within range (optional for height)
            math.random(-radius, radius)   -- Random z within range
        )
        
        local targetPosition = humanoidRootPart.Position + randomOffset

        local args = {
            [1] = targetPosition,
            [2] = targetPosition + Vector3.new(0, 0, 0)
