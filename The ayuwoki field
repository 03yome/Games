local ItemsESPEnabled = false
local ITEM_ESP_TAG = "_item_premium_esp"

local ItemConfig = {
	["Camara"]          = {English = "Camera",     Color = Color3.fromRGB(0, 200, 255)},
	["Mapa"]            = {English = "Map",        Color = Color3.fromRGB(255, 200, 0)},
	["Rastreador"]      = {English = "Tracker",    Color = Color3.fromRGB(255, 50, 50)},
	["Soda"]            = {English = "Soda",        Color = Color3.fromRGB(250, 100, 250)},
	["BarraEnergetica"] = {English = "Energy Bar", Color = Color3.fromRGB(50, 255, 100)},
	["Vendas"]          = {English = "Bandages",   Color = Color3.fromRGB(230, 230, 240)},
	["Escoba"]          = {English = "Broom",      Color = Color3.fromRGB(200, 120, 50)}
}

local function verifyValidItem(obj)
	if not obj or not obj:IsDescendantOf(Workspace) then return false end

	for _, p in ipairs(Players:GetPlayers()) do
		if p.Character and obj:IsDescendantOf(p.Character) then return false end
		local bp = p:FindFirstChild("Backpack")
		if bp and obj:IsDescendantOf(bp) then return false end
	end

	if obj:IsA("BasePart") and obj.Transparency >= 0.95 then
		return false
	elseif obj:IsA("Model") then
		local representative = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
		if representative and representative.Transparency >= 0.95 then return false end
	end

	return true
end

local function attachItemESP(obj)
	if not obj:IsA("BasePart") and not obj:IsA("Model") then return end
	if obj:FindFirstChild(ITEM_ESP_TAG) then return end
	
	local itemData = ItemConfig[obj.Name]
	if not itemData then return end
	if not verifyValidItem(obj) then return end

	local customColor = itemData.Color
	local engName = itemData.English

	local h = Instance.new("Highlight")
	h.Name = ITEM_ESP_TAG
	h.Adornee = obj
	h.FillColor = customColor
	h.OutlineColor = customColor
	h.FillTransparency = 0.4
	h.OutlineTransparency = 0
	h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	h.Parent = obj

	local billboard = Instance.new("BillboardGui")
	billboard.Name = ITEM_ESP_TAG .. "_text"
	billboard.Size = UDim2.new(0, 150, 0, 30)
	billboard.AlwaysOnTop = true
	billboard.MaxDistance = math.huge
	billboard.StudsOffset = Vector3.new(0, 1.5, 0)
	billboard.Parent = obj

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, 0, 1, 0)
	label.BackgroundTransparency = 1
	label.Text = engName .. " [Checking...]"
	label.Font = Enum.Font.GothamBold
	label.TextColor3 = customColor
	label.TextSize = 10
	label.TextStrokeTransparency = 0.4
	label.TextStrokeColor3 = Color3.new(0, 0, 0)
	label.Parent = billboard

	if obj:IsA("BasePart") then
		billboard.Adornee = obj
	else
		billboard.Adornee = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart") or obj
	end

	task.spawn(function()
		while billboard.Parent and ItemsESPEnabled do
			if not verifyValidItem(obj) then
				h:Destroy()
				billboard:Destroy()
				break
			end
			
			local myChar = Player.Character
			if myChar and myChar:FindFirstChild("HumanoidRootPart") and billboard.Adornee then
				local targetPos = billboard.Adornee:IsA("BasePart") and billboard.Adornee.Position or billboard.Adornee:GetPivot().Position
				if targetPos then
					local dist = (myChar.HumanoidRootPart.Position - targetPos).Magnitude
					local meters = math.floor(dist * 0.28)
					label.Text = string.format("%s [%dm]", engName, meters)
				end
			end
			task.wait(0.2)
		end
	end)
end

local function cleanItemsESP()
	for _, v in ipairs(Workspace:GetDescendants()) do
		if v.Name == ITEM_ESP_TAG or v.Name == ITEM_ESP_TAG .. "_text" then
			v:Destroy()
		end
	end
end

local function scanAndApplyItemsESP()
	if not ItemsESPEnabled then return end
	for _, v in ipairs(Workspace:GetDescendants()) do
		if ItemConfig[v.Name] then
			attachItemESP(v)
		end
	end
end

Workspace.DescendantAdded:Connect(function(v)
	if not ItemsESPEnabled then return end
	
	if ItemConfig[v.Name] then
		task.wait(0.1)
		attachItemESP(v)
	else
		local nameConnection
		nameConnection = v:GetPropertyChangedSignal("Name"):Connect(function()
			if not ItemsESPEnabled or not v.Parent then
				nameConnection:Disconnect()
				return
			end
			if ItemConfig[v.Name] then
				nameConnection:Disconnect()
				task.wait(0.1)
				attachItemESP(v)
			end
		end)
		task.delay(5, function() if nameConnection then nameConnection:Disconnect() end end)
	end
end)

task.spawn(function()
	while true do
		task.wait(3.5)
		if ItemsESPEnabled then
			scanAndApplyItemsESP()
		end
	end
end)

local function toggleItemsESP()
	ItemsESPEnabled = not ItemsESPEnabled
	animateToggle(ItemsESPBtn, ItemsStroke, ItemsESPEnabled, "Items ESP", Color3.fromRGB(90, 35, 130), Color3.fromRGB(160, 60, 230))
	if ItemsESPEnabled then
		scanAndApplyItemsESP()
	else
		cleanItemsESP()
	end
end

