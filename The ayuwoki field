local function createESP(model)
    local p = model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart")
    if not p then return end

    if not model:FindFirstChild("ModelESP") then
        local box = Instance.new("BoxHandleAdornment")
        box.Name = "ModelESP"
        box.Adornee = p
        box.Size = model:GetExtentsSize()
        box.Color3 = Color3.new(0, 1, 0)
        box.Transparency = 0.3
        box.AlwaysOnTop = true
        box.ZIndex = 5
        box.Parent = model
    end
end

local function cleanMonsterESP()
    for _, v in ipairs(Workspace:GetChildren()) do
        local box = v:FindFirstChild("ModelESP")
        if box then box:Destroy() end
    end
    local oldGui = game.CoreGui:FindFirstChild("WarnGui")
    if oldGui then oldGui:Destroy() end
    WarnScreenGui = nil
    WarnTextLabel = nil
end

RunService.RenderStepped:Connect(function()
    if not getgenv().ESP_ENABLED then return end

    local char = Player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local nearestDist = math.huge
    local nearestModel = nil

    for _, obj in ipairs(Workspace:GetChildren()) do
        if obj:IsA("Model") and obj.Name == "Ayuwoki" then
            createESP(obj)

            local part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
            if part then
                local dist = (hrp.Position - part.Position).Magnitude
                if dist < nearestDist then
                    nearestDist = dist
                    nearestModel = obj
                end
            end
        end
    end

    if nearestModel and nearestDist and WarnTextLabel then
        if nearestDist <= 101 then
            WarnTextLabel.Text = "⚠ NGUY HIỂM – RẤT GẦN ("..math.floor(nearestDist)..")"
            WarnTextLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
            WarnTextLabel.Visible = true
        elseif nearestDist <= 201 then
            WarnTextLabel.Text = "⚠ CẢNH BÁO – GẦN ("..math.floor(nearestDist)..")"
            WarnTextLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
            WarnTextLabel.Visible = true
        elseif nearestDist <= 550 then
            WarnTextLabel.Text = "✔ AN TOÀN – XA ("..math.floor(nearestDist)..")"
            WarnTextLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
            WarnTextLabel.Visible = true
        else
            WarnTextLabel.Visible = false
        end
    else
        if WarnTextLabel then WarnTextLabel.Visible = false end
    end
end)

