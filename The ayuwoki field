local FullBrightEnabled = false
local FullBrightConnections = {}

local function applyFullBright()
	if not FullBrightEnabled then return end
	Lighting.Ambient, Lighting.OutdoorAmbient = Color3.new(1, 1, 1), Color3.new(1, 1, 1)
	Lighting.Brightness, Lighting.FogEnd = 3, 100000
	Lighting.GlobalShadows, Lighting.ClockTime = false, 14
end

local function setupFullBrightProtection()
	for _, conn in pairs(FullBrightConnections) do conn:Disconnect() end
	table.clear(FullBrightConnections)
	local properties = {"Ambient", "OutdoorAmbient", "Brightness", "FogEnd", "GlobalShadows", "ClockTime"}
	for _, prop in ipairs(properties) do
		table.insert(FullBrightConnections, Lighting:GetPropertyChangedSignal(prop):Connect(function()
			if FullBrightEnabled then task.defer(applyFullBright) end
		end))
	end
end

local function toggleFullBright()
	FullBrightEnabled = not FullBrightEnabled
	animateToggle(FullBrightBtn, FBtnStroke, FullBrightEnabled, "Visual Full Bright", Color3.fromRGB(45, 105, 65), Color3.fromRGB(65, 180, 100))
	if FullBrightEnabled then applyFullBright() setupFullBrightProtection() else Lighting.GlobalShadows = true end
end

