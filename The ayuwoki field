local function animateToggle(btn, stroke, state, textPrefix, activeColor, activeStroke)
	if state then
		btn.Text = textPrefix .. " : ON"
		TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = activeColor, TextColor3 = Color3.new(1, 1, 1)}):Play()
		TweenService:Create(stroke, TweenInfo.new(0.2), {Color = activeStroke}):Play()
	else
		btn.Text = textPrefix .. " : OFF"
		TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(25, 25, 30), TextColor3 = Color3.fromRGB(200, 200, 210)}):Play()
		TweenService:Create(stroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(38, 38, 45)}):Play()
	end
end

--------------------------------------------------
-- INDEPENDENT POSITION DRAGGING HANDLER
--------------------------------------------------
local function makeDraggable(frame, identityKey)
	local dragging, dragInput, dragStart, startPos
	
	frame.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = frame.Position
			input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
		end
	end)

	frame.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
	end)

	UIS.InputChanged:Connect(function(input)
		if input == dragInput and dragging then
			local delta = input.Position - dragStart
			local targetPos = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
			frame.Position = targetPos
			
			if identityKey == "MAIN" then
				LastMainPosition = targetPos
			elseif identityKey == "CIRCLE" then
				LastCirclePosition = targetPos
				CircleHasBeenMoved = true
			end
		end
	end)
end

