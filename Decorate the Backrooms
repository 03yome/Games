Tab:AddButton({
    Title = "Delete Guard",
    Icon = "solar/map-point-bold",
    Callback = function()
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer
local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()

LocalPlayer.CharacterAdded:Connect(function(newChar)
	Character = newChar
end)

local function getRoot(char)
	if not char then return nil end
	return char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
end

local function getGamePhase()
	local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
	if not playerGui then return "Day" end
	
	local phaseLabel = playerGui:FindFirstChild("Top")
		and playerGui.Top:FindFirstChild("Holder")
		and playerGui.Top.Holder:FindFirstChild("Top")
		and playerGui.Top.Holder.Top:FindFirstChild("Phase")
		
	if phaseLabel and phaseLabel:IsA("TextLabel") then
		local text = phaseLabel.Text
		if string.find(text, "Night") then
			return "Night"
		elseif string.find(text, "Day") then
			return "Day"
		end
	end
	
	return "Day"
end

local function deleteAllMapParts()
	for _, item in pairs(Workspace:GetDescendants()) do
		if item:IsA("BasePart") or item:IsA("Terrain") then
			local isProtected = false
			
			if Character and item:IsDescendantOf(Character) then
				isProtected = true
			end
			
			if not isProtected then
				local parentModel = item:FindFirstAncestorOfClass("Model")
				if parentModel and string.find(parentModel.Name, "NightGuard") then
					isProtected = true
				end
			end
			
			if not isProtected then
				pcall(function()
					item:Destroy()
				end)
			end
		end
	end
end

local function isNPCKilled(npc)
	if not npc or not npc.Parent then return true end
	
	local hasParts = false
	for _, child in pairs(npc:GetDescendants()) do
		if child:IsA("BasePart") then
			hasParts = true
			break
		end
	end
	if not hasParts then return true end

	local hrp = getRoot(npc)
	if not hrp or hrp.Position.Y < -100 then
		return true
	end

	return false
end

local function getValidTargets()
	local targets = {}
	for _, obj in pairs(Workspace:GetDescendants()) do
		if obj:IsA("Model") and string.find(obj.Name, "NightGuard") then
			if not isNPCKilled(obj) then
				table.insert(targets, obj)
			end
		end
	end
	return targets
end

local function mainLogic()
	local rootPart = getRoot(Character)
	if not Character or not rootPart then return end

	local noclipConnection = RunService.Stepped:Connect(function()
		if Character then
			for _, part in pairs(Character:GetDescendants()) do
				if part:IsA("BasePart") then
					part.CanCollide = false
				end
			end
		end
	end)

	deleteAllMapParts()

	local currentPhase = getGamePhase()

	if currentPhase == "Day" then
		local bodyPos = Instance.new("BodyPosition")
		bodyPos.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
		bodyPos.Position = rootPart.Position
		bodyPos.Parent = rootPart

		local bambam = Instance.new("BodyAngularVelocity")
		bambam.Name = "FlingVelocity"
		bambam.Parent = rootPart
		bambam.AngularVelocity = Vector3.new(0, 99999, 0)
		bambam.MaxTorque = Vector3.new(0, math.huge, 0)
		bambam.P = math.huge

		for _, child in pairs(Character:GetDescendants()) do
			if child:IsA("BasePart") then
				child.CustomPhysicalProperties = PhysicalProperties.new(100, 0.3, 0.5)
				child.Massless = true
				child.Velocity = Vector3.new(0, 0, 0)
			end
		end

		local isSpinning = true
		task.spawn(function()
			while isSpinning and bambam and bambam.Parent do
				bambam.AngularVelocity = Vector3.new(0, 99999, 0)
				task.wait(0.2)
				if bambam and bambam.Parent then
					bambam.AngularVelocity = Vector3.new(0, 0, 0)
				end
				task.wait(0.1)
			end
		end)

		local targets = getValidTargets()
		for _, targetNPC in ipairs(targets) do
			if not isNPCKilled(targetNPC) then
				local npcHRP = getRoot(targetNPC)
				local startTime = tick()
				
				while npcHRP and npcHRP.Parent and not isNPCKilled(targetNPC) and (tick() - startTime < 5) do
					local closePosition = npcHRP.CFrame * CFrame.new(0, 0, -1)
					
					bodyPos.Position = closePosition.Position
					rootPart.CFrame = closePosition
					npcHRP.AssemblyLinearVelocity = Vector3.new(0, -1000, 0)
					
					RunService.Heartbeat:Wait()
				end
			end
		end

		isSpinning = false
		if bodyPos then bodyPos:Destroy() end
		if bambam then bambam:Destroy() end

	elseif currentPhase == "Night" then
		-- Đảm bảo vật lý bình thường (không fling)
		for _, child in pairs(Character:GetDescendants()) do
			if child:IsA("BasePart") then
				child.CustomPhysicalProperties = nil
				child.Massless = false
			end
		end

		while getGamePhase() == "Night" do
			local targets = getValidTargets()
			if #targets == 0 then
				break
			end

			for _, targetNPC in ipairs(targets) do
				if not isNPCKilled(targetNPC) then
					local npcHRP = getRoot(targetNPC)
					local startTime = tick()
					
					while npcHRP and npcHRP.Parent and not isNPCKilled(targetNPC) and getGamePhase() == "Night" and (tick() - startTime < 10) do
						local frontCFrame = npcHRP.CFrame * CFrame.new(0, 2, -14) * CFrame.Angles(0, math.pi, 0)
						rootPart.CFrame = frontCFrame
						
						RunService.Heartbeat:Wait()
					end
				end
			end
			RunService.Heartbeat:Wait()
		end
	end

	if noclipConnection then noclipConnection:Disconnect() end
end

mainLogic()
    end
})

