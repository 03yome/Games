-- ===== TIMER LOGIC =====
local running = false

local function startTimer(minutes)
    running = false
    task.wait()
    running = true

    local total = minutes * 60

    for i = total, 0, -1 do
        if not running then break end

        local m = math.floor(i/60)
        local s = i % 60

        label.Text = string.format("%02d:%02d", m, s)
        task.wait(1)
    end

    if running then
        label.Text = "DONE"
    end
end

-- ===== TẠO NÚT TRONG SETTINGS =====
local function createButton(text, posY, minutes)
    local btn = Instance.new("TextButton")
    btn.Parent = menu
    btn.Size = UDim2.new(1, 0, 0, 30)
    btn.Position = UDim2.new(0, 0, 0, posY)
    btn.Text = text
    btn.TextScaled = true
    btn.BackgroundColor3 = Color3.fromRGB(0,170,255)

    btn.MouseButton1Click:Connect(function()
        task.spawn(startTimer, minutes)
    end)
end

