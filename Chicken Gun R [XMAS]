local player = game.Players.LocalPlayer

local running = false

local function touch(hitbox)
    local char = player.Character or player.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")

    if hitbox then
        firetouchinterest(hrp, hitbox, 0)
        task.wait()
        firetouchinterest(hrp, hitbox, 1)
    end
end

local function autoLoot()
    while running do
        local itemCache = workspace:FindFirstChild("ItemCache")

        if itemCache then
            for _, v in pairs(itemCache:GetDescendants()) do
                if v.Name == "Hitbox" and v.Parent then
                    if v.Parent.Name == "ArmorPack" or v.Parent.Name == "HealthPack" then
                        touch(v)
                    end
                end
            end
        end

        wait(0.5)
    end
end

