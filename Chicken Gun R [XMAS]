-- ===== BIẾN GIÁ =====
local Price = 50

-- ===== INPUT GIÁ =====
Tab:CreateInput({
    Name = "Price",
    PlaceholderText = "Enter price",
    RemoveTextAfterFocusLost = false,
    Callback = function(text)
        local num = tonumber(text)
        if num then
            Price = num
        end
    end
})

Tab:CreateInput({
    Name = "Nhập số (đảo dấu)",
    PlaceholderText = "VD: 20 hoặc -20",
    RemoveTextAfterFocusLost = false,
    Callback = function(Text)
        local value = tonumber(Text)
        if not value then
            Rayfield:Notify({
                Title = "Lỗi",
                Content = "Vui lòng nhập số hợp lệ",
                Duration = 3
            })
            return
        end

        -- 🔁 đảo dấu
        local finalValue = -value

        local args = {
            game:GetService("Players").LocalPlayer
                :WaitForChild("Hidden_leaderstats")
                :WaitForChild("ShopPurchases")
                :WaitForChild("Face")
                :WaitForChild("Xmas Shades"),

            "Customization",
            finalValue,
            game:GetService("Players").LocalPlayer
                :WaitForChild("Hidden_leaderstats")
                :WaitForChild("Matches")
        }

        game:GetService("ReplicatedStorage")
            :WaitForChild("Modules")
            :WaitForChild("RemoteFunc_Module")
            :WaitForChild("MatchesEventClient")
            :FireServer(unpack(args))

        Rayfield:Notify({
            Title = "Đã gửi",
            Content = "Giá trị gửi: "..finalValue,
            Duration = 3
        })
    end
})

