                followingHitbox = true,
                _debuff_startdelay = 0
            },
            hitCharacter = target,
            hitboxDamage = 99.9,
            hitboxDepth = 8,
            knockback = true,
            hitboxPosition = pos
        }
    }

    Remote:FireServer(unpack(args))
