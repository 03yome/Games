-- Chờ game tải xong hoàn toàn
if not game:IsLoaded() then game.Loaded:Wait() end

-- Khởi tạo dịch vụ
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local CoreGui = game:GetService("CoreGui")
local UserInputService = game:GetService("UserInputService")

local collectOrbEvent = ReplicatedStorage:WaitForChild("CollectOrb", 5)
local swapCharacterEvent = ReplicatedStorage:WaitForChild("SwapCharacter", 5)

if not collectOrbEvent or not swapCharacterEvent then
    warn("Không tìm thấy các RemoteEvent của game!")
    return
end

-- Tạo GUI bảo mật cho Executor
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "Executor_Input_Menu"
screenGui.ResetOnSpawn = false

if syn and syn.protect_gui then syn.protect_gui(screenGui)
elseif gethui then screenGui.Parent = gethui()
else screenGui.Parent = CoreGui end

-- Khung nền chính (Tăng chiều cao lên 220 để vừa ô nhập)
local mainFrame = Instance.new("Frame")
mainFrame.Size = UDim2.new(0, 240, 0, 220)
mainFrame.Position = UDim2.new(0.1, 0, 0.3, 0)
mainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
mainFrame.BorderSizePixel = 0
mainFrame.Active = true
mainFrame.Draggable = true
mainFrame.Parent = screenGui

local frameCorner = Instance.new("UICorner")
frameCorner.CornerRadius = UDim.new(0, 10)
frameCorner.Parent = mainFrame

-- Tiêu đề
local titleLabel = Instance.new("TextLabel")
titleLabel.Size = UDim2.new(1, 0, 0, 30)
titleLabel.BackgroundTransparency = 1
titleLabel.Text = "MENU TÙY CHỈNH [Insert để ẩn]"
titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
titleLabel.Font = Enum.Font.SourceSansBold
titleLabel.TextSize = 14
titleLabel.Parent = mainFrame

---------------------------------------------------------
-- PHẦN 1: THU THẬP ORB (NHẬP SỐ)
---------------------------------------------------------
-- Ô nhập số lượng Orb
local inputOrb = Instance.new("TextBox")
inputOrb.Size = UDim2.new(0, 100, 0, 35)
inputOrb.Position = UDim2.new(0, 10, 0, 45)
inputOrb.Text = "10" -- Giá trị mặc định
inputOrb.PlaceholderText = "Số lượng..."
inputOrb.TextColor3 = Color3.fromRGB(255, 255, 255)
inputOrb.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
inputOrb.Font = Enum.Font.SourceSans
inputOrb.TextSize = 16
inputOrb.Parent = mainFrame
Instance.new("UICorner", inputOrb).CornerRadius = UDim.new(0, 5)

-- Nút bấm gửi lệnh Orb
local btnOrb = Instance.new("TextButton")
btnOrb.Size = UDim2.new(0, 110, 0, 35)
btnOrb.Position = UDim2.new(0, 120, 0, 45)
btnOrb.Text = "Nhận Orb"
btnOrb.TextColor3 = Color3.fromRGB(255, 255, 255)
btnOrb.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
btnOrb.Font = Enum.Font.SourceSansBold
btnOrb.TextSize = 15
btnOrb.Parent = mainFrame
Instance.new("UICorner", btnOrb).CornerRadius = UDim.new(0, 5)

btnOrb.MouseButton1Click:Connect(function()
    local targetValue = tonumber(inputOrb.Text)
    if targetValue then
        collectOrbEvent:FireServer(unpack({ targetValue }))
        print("Đã gửi Orb với giá trị: " .. targetValue)
    else
        print("Vui lòng nhập một số hợp lệ vào ô Orb!")
    end
end)

---------------------------------------------------------
-- PHẦN 2: ĐỔI NHÂN VẬT (NHẬP LEVEL)
---------------------------------------------------------
-- Ô nhập tên Level nhân vật
local inputLevel = Instance.new("TextBox")
inputLevel.Size = UDim2.new(0, 100, 0, 35)
inputLevel.Position = UDim2.new(0, 10, 0, 100)
inputLevel.Text = "Level12" -- Giá trị mặc định
inputLevel.PlaceholderText = "Tên Level..."
inputLevel.TextColor3 = Color3.fromRGB(255, 255, 255)
inputLevel.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
inputLevel.Font = Enum.Font.SourceSans
inputLevel.TextSize = 14
inputLevel.Parent = mainFrame
Instance.new("UICorner", inputLevel).CornerRadius = UDim.new(0, 5)

-- Nút bấm gửi lệnh Đổi nhân vật
local btnSwap = Instance.new("TextButton")
btnSwap.Size = UDim2.new(0, 110, 0, 35)
btnSwap.Position = UDim2.new(0, 120, 0, 100)
btnSwap.Text = "Đổi Nhân Vật"
btnSwap.TextColor3 = Color3.fromRGB(255, 255, 255)
btnSwap.BackgroundColor3 = Color3.fromRGB(220, 50, 50)
btnSwap.Font = Enum.Font.SourceSansBold
btnSwap.TextSize = 15
btnSwap.Parent = mainFrame
Instance.new("UICorner", btnSwap).CornerRadius = UDim.new(0, 5)

btnSwap.MouseButton1Click:Connect(function()
    local targetLevel = inputLevel.Text
    if targetLevel and targetLevel ~= "" then
        swapCharacterEvent:FireServer(unpack({ targetLevel }))
        print("Đã gửi yêu cầu đổi sang: " .. targetLevel)
    end
end)

---------------------------------------------------------
-- PHẦN 3: NÚT SPAM/AUTO (Tặng kèm để bạn rảnh tay)
---------------------------------------------------------
local btnAuto = Instance.new("TextButton")
btnAuto.Size = UDim2.new(0, 220, 0, 40)
btnAuto.Position = UDim2.new(0, 10, 0, 160)
btnAuto.Text = "Auto Thu Thập: TẮT"
btnAuto.TextColor3 = Color3.fromRGB(255, 255, 255)
btnAuto.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
btnAuto.Font = Enum.Font.SourceSansBold
btnAuto.TextSize = 16
btnAuto.Parent = mainFrame
Instance.new("UICorner", btnAuto).CornerRadius = UDim.new(0, 6)

local autoEnabled = false
btnAuto.MouseButton1Click:Connect(function()
    autoEnabled = not autoEnabled
    if autoEnabled then
        btnAuto.Text = "Auto Thu Thập: BẬT"
        btnAuto.BackgroundColor3 = Color3.fromRGB(46, 204, 113)
        -- Chạy vòng lặp tự động gửi lệnh Orb liên tục
        task.spawn(function()
            while autoEnabled do
                local targetValue = tonumber(inputOrb.Text)
                if targetValue then
                    collectOrbEvent:FireServer(unpack({ targetValue }))
                end
                task.wait(0.1) -- Khoảng cách giữa các lần gửi (0.5 giây), bạn có thể chỉnh nhỏ lại nếu muốn nhanh hơn
            end
        end)
    else
        btnAuto.Text = "Auto Thu Thập: TẮT"
        btnAuto.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    end
end)

-- Ẩn/Hiện Menu bằng phím Insert
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.KeyCode == Enum.KeyCode.Insert then
        mainFrame.Visible = not mainFrame.Visible
    end
end)
