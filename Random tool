Tabs.Main3:AddButton({
    Title = 'Half-Zatoichi',
    Description = 'Instant Charge Use',
    Callback = function()
        local player = game:GetService('Players').LocalPlayer
        local tool = (player.Character or player.CharacterAdded:Wait()):WaitForChild('Half-Zatoichi [0]')
        local startCharge = tool.WaitForChild(tool, 'StartCharge')

        local function getCharge(name)
            local num = string.match(name, '%[(%d+)%]')
            return tonumber(num)
        end

        tool.GetPropertyChangedSignal(tool, 'Name'):Connect(function()
            local charge = getCharge(tool.Name)

            if charge and (0 <= charge and charge <= 25) then
                startCharge:FireServer()
            end
        end)
    end,
})

