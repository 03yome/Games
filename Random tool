Tabs.Main2:AddButton({
    Title = 'Damage All',
    Description = '1 Time',
    Callback = function()
        local Players = game:GetService('Players')
        local LocalPlayer = Players.LocalPlayer
        local Tool = (LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()):FindFirstChildOfClass('Tool')

        if Tool then
            local iter, state, index = ipairs(Players:GetPlayers())

            local remotes = {
                damage = function(player)
                    return {
                        player.Character:FindFirstChild('Humanoid'),
                    }
                end,

                damageAndGrip = function(player)
                    return {
                        player.Character:FindFirstChild('Humanoid'),
                        true,
                    }
                end,
            }

            while true do
                local player
                index, player = iter(state, index)

                if index == nil then
                    break
                end

                if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild('Humanoid') then
                    local rIter, rState, rIndex = pairs(remotes)

                    while true do
                        local func
                        rIndex, func = rIter(rState, rIndex)

                        if rIndex == nil then
                            break
                        end

                        local remote = Tool:FindFirstChild(rIndex)

                        if remote and remote:IsA('RemoteFunction') then
                            local args = func(player)
                            remote:InvokeServer(unpack(args))
                        end
                    end
                end
            end
        end
    end,
})

