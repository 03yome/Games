    REMASTERED SCRIPT: AUTO-DODGE (HYBRID) & TRACKER & DROPDOWN
    - Kết hợp: Quét chữ trên màn hình + Spam Remote né liên tục.
    - Giao diện: Tối ưu Mobile, RGB Border.
]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local pGui = player:WaitForChild("PlayerGui")
local isAutoDodgeEnabled = false

---------------------------------------------------
-- 1. HỆ THỐNG AUTO-DODGE (GỘP LOGIC)
---------------------------------------------------
local dodgeRemote = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Dodge")
local dodgeKeys = {"E", "C", "X", "Z", "G", "F", "Q", "R"}
local keyDict = {C = true, R = true, Q = true, E = true, Z = true}

-- Logic 1: Né khi phát hiện chữ (Passive)
local function handleTextDodge(text)
    if isAutoDodgeEnabled then
        local key = string.upper(text)
        if keyDict[key] then
            pcall(function() dodgeRemote:FireServer(key) end)
        end
    end
end

pGui.DescendantAdded:Connect(function(obj)
    if obj:IsA("TextLabel") or obj:IsA("TextBox") then
        obj:GetPropertyChangedSignal("Text"):Connect(function() handleTextDodge(obj.Text) end)
    end
end)

-- Logic 2: Spam né chủ động (Active)
task.spawn(function()
    while true do
        if isAutoDodgeEnabled then
            for _, key in ipairs(dodgeKeys) do
                pcall(function() dodgeRemote:FireServer(key) end)
            end
        end
        task.wait(0.1) -- Khoảng nghỉ để tránh lag/kick
    end
end)

