end)
TimeInput.FocusLost:Connect(function() hideTime = tonumber(TimeInput.Text) or 3 end)

local function getSlapper()
    local char = LocalPlayer.Character
    if not char then return nil end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local dist = (char.PrimaryPart.Position - p.Character.PrimaryPart.Position).Magnitude
            if dist < 12 then
                local hum = p.Character:FindFirstChildOfClass("Humanoid")
                for _, anim in pairs(hum:GetPlayingAnimationTracks()) do
                    if not IgnoreList[anim.Animation.AnimationId] and not IgnoreList[anim.Name] then
                        return p
                    end
                end
            end
        end
    end
    return nil
end

local function setup(char)
    local hum = char:WaitForChild("Humanoid")
    local lastHealth = hum.Health
    hum.HealthChanged:Connect(function(hp)
        if isEnabled and hp < lastHealth then
            local slapper = getSlapper()
            if slapper then
                NameLabel.Text = "⚠️ " .. slapper.DisplayName .. " Slap!"
                AvatarImg.Image = ""
                NotifyFrame.Visible = true
                task.spawn(function()
                    local img = Players:GetUserThumbnailAsync(slapper.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size100x100)
                    AvatarImg.Image = img
                end)
                task.delay(hideTime, function() NotifyFrame.Visible = false end)
            end
        end
        lastHealth = hp
    end)
end

if LocalPlayer.Character then setup(LocalPlayer.Character) end
LocalPlayer.CharacterAdded:Connect(setup)
