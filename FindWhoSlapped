local isEnabled = false
local hideTime = 3
local IgnoreList = {["rbxassetid://180426354"] = true, ["rbxassetid://106298297854897"] = true, ["WalkAnim"] = true, ["Idle"] = true, ["Jump"] = true}

OpenBtn.MouseButton1Click:Connect(function() MainFrame.Visible = not MainFrame.Visible end)
