local autoReviveConnection = nil

local Toggle = Tab:CreateToggle({
   Name = "Auto Respawn",
   CurrentValue = false,
   Flag = "AutoDeathRevive1", 
   Callback = function(Value)
        _G.AutoRevive = Value

        if Value then
            local function checkAndRevive(character)
                local humanoid = character:WaitForChild("Humanoid", 5)
                if humanoid then
                    autoReviveConnection = humanoid.HealthChanged:Connect(function(health)
                        if health <= 0 and _G.AutoRevive then
                            game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("DeathRevive"):FireServer()
                        end
                    end)
                end
            end

            local localPlayer = game.Players.LocalPlayer
            if localPlayer.Character then
                checkAndRevive(localPlayer.Character)
            end

            localPlayer.CharacterAdded:Connect(function(newCharacter)
                if _G.AutoRevive then
                    if autoReviveConnection then autoReviveConnection:Disconnect() end
                    checkAndRevive(newCharacter)
                end
            end)

        else
            if autoReviveConnection then
                autoReviveConnection:Disconnect()
                autoReviveConnection = nil
            end
        end
   end,
})
