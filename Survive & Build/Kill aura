-- 2 LUỒNG CHẠY SONG SONG ĐỘC LẬP
----------------------------------------------------------------

-- LUỒNG 1: ĐÁNH QUÁI (TỰ ĐỘNG PHÂN CHIA SÁT THƯƠNG THEO MỐC)
task.spawn(function()
    while true do
        local charactersFolder = workspace:FindFirstChild("CHARACTERS")
        local myChar = LocalPlayer.Character or (charactersFolder and charactersFolder:FindFirstChild(LocalPlayer.Name))
        local myWeapon = myChar and myChar:FindFirstChild("Weapon")
        local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
        
        if myWeapon and myRoot then
            local mobsFolder = workspace:FindFirstChild("MOBS")
            if mobsFolder then
                for _, mob in pairs(mobsFolder:GetChildren()) do
                    local mTorso = mob:FindFirstChild("Torso") or mob:FindFirstChild("UpperTorso") or mob:FindFirstChild("HumanoidRootPart")
                    local mHum = mob:FindFirstChild("Humanoid")
                    
                    if mTorso and mHum and mHum.Health > 0 then
                        -- [ĐÒN ĐÁNH 1 - TÀN SÁT THƯỜNG]: Không giới hạn khoảng cách khi dưới 50% máu
                        if isRageActive then
                            sendDamage(myWeapon, mTorso, mHum)
                        end
                        
                        -- [ĐÒN ĐÁNH 2 - TÀN SÁT X2]: Đánh thêm một phát nữa toàn map khi dưới 35% máu (Kích hoạt x2)
                        if isSuperRage then
                            sendDamage(myWeapon, mTorso, mHum)
                        end
                        
                        -- [ĐÒN ĐÁNH TỪ GUI THƯỜNG]: Chỉ đánh khi nút bật và quái trong tầm 60 studs
                        if _G.MobAuraEnabled then
                            local distance = (myRoot.Position - mTorso.Position).Magnitude
                            if distance <= _G.MaxDistance then
                                sendDamage(myWeapon, mTorso, mHum)
                            end
                        end
                    end
                end
            end
        end
        -- Tăng tốc độ spam khi ở trạng thái tàn sát
        task.wait(isRageActive and 0.02 or _G.AttackDelay)
    end
end)

-- LUỒNG 2: ĐÁNH PLAYER ĐÃ CHỌN (workspace.CHARACTERS)
task.spawn(function()
    while true do
        if targetPlayer then
            local charactersFolder = workspace:FindFirstChild("CHARACTERS")
            local myChar = LocalPlayer.Character or (charactersFolder and charactersFolder:FindFirstChild(LocalPlayer.Name))
            local myWeapon = myChar and myChar:FindFirstChild("Weapon")
            
            local tChar = charactersFolder and charactersFolder:FindFirstChild(targetPlayer.Name)
            local tRoot = tChar and tChar:FindFirstChild("HumanoidRootPart")
            local tHum = tChar and tChar:FindFirstChild("Humanoid")
            
            if myWeapon and tRoot and tHum and tHum.Health > 0 then
                sendDamage(myWeapon, tRoot, tHum)
                
                if not isLoopingPlayer then
                    targetPlayer = nil
                end
            else
                targetPlayer = nil
                isLoopingPlayer = false
            end
        end
        task.wait(_G.AttackDelay)
    end
end)
