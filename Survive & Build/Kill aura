----------------------------------------------------------------
-- CORE LOGIC: GỬI LỆNH ĐÁNH
----------------------------------------------------------------
local function sendDamage(weapon, targetRoot, targetHumanoid)
    if weapon and targetRoot and targetHumanoid and targetHumanoid.Health > 0 then
        local args = {
            [1] = weapon,
            [2] = "Attack",
            [3] = targetRoot,
            [4] = targetHumanoid,
            n = 4,
        }
        pcall(function()
            DamageFunction:InvokeServer(unpack(args, 1, args.n or #args))
        end)
    end
end

----------------------------------------------------------------
-- VÒNG LẶP ĐẾM NGƯỢC THỜI GIAN TÀN SÁT NÂNG CAO
----------------------------------------------------------------
task.spawn(function()
    while true do
        if isRageActive then
            rageTimeLeft = rageTimeLeft - 1
            if isSuperRage then
                RageStatusLabel.Text = "TÀN SÁT X2: " .. rageTimeLeft .. "s"
                RageStatusLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
            else
                RageStatusLabel.Text = "TÀN SÁT: " .. rageTimeLeft .. "s"
                RageStatusLabel.TextColor3 = Color3.fromRGB(255, 150, 0)
            end
            
            if rageTimeLeft <= 0 then
                isRageActive = false
                isSuperRage = false
                RageStatusLabel.Text = "TRẠNG THÁI: BÌNH THƯỜNG"
                RageStatusLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
            end
        end
        task.wait(1)
    end
end)

----------------------------------------------------------------
-- LUỒNG QUẢN LÝ THEO DÕI MÁU (XỬ LÝ MỐC 50% VÀ MỐC 35%)
----------------------------------------------------------------
task.spawn(function()
    while true do
        local charactersFolder = workspace:FindFirstChild("CHARACTERS")
        local myChar = LocalPlayer.Character or (charactersFolder and charactersFolder:FindFirstChild(LocalPlayer.Name))
        local myHum = myChar and myChar:FindFirstChild("Humanoid")
        
        if myHum and myHum.Health > 0 then
            local currentHealthPercent = myHum.Health / myHum.MaxHealth
            
            -- BƯỚC 1: Kiểm tra mốc dưới 50% để bật Tàn sát thường
            if currentHealthPercent <= 0.70 and not isRageActive then
                isRageActive = true
                isSuperRage = false
                rageTimeLeft = 50 -- Thiết lập thời gian ban đầu là 30 giây
            end
            
            -- BƯỚC 2: Nếu đang trong 30 giây tàn sát mà máu tiếp tục tụt xuống dưới 35%
            if isRageActive and not isSuperRage and currentHealthPercent <= 0.50 then
                isSuperRage = true
                rageTimeLeft = rageTimeLeft + 60 -- Cộng thêm 15 giây tàn sát
            end
        end
        task.wait(0.2) -- Tăng tần suất quét máu để bắt mốc kịp thời
    end
end)

